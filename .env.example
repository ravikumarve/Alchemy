# ALCHEMY - Temporal Content Transmuter
# Environment Configuration

# Application
APP_NAME="ALCHEMY - Temporal Content Transmuter"
APP_VERSION="1.0.0"
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=sqlite:///./alchemy.db
DATABASE_ECHO=false

# Processing
MAX_FILE_SIZE=104857600
TIMEOUT_SECONDS=80
RETRY_COUNT=3
MAX_CONCURRENT_JOBS=5

# Time Budgets (in seconds)
TIME_BUDGET_VALIDATE_FILE=5.0
TIME_BUDGET_EXTRACT_CONTENT=2.0
TIME_BUDGET_ANALYZE_SEMANTICS=30.0
TIME_BUDGET_STRUCTURE_DATA=20.0
TIME_BUDGET_FILTER_QUALITY=15.0
TIME_BUDGET_ENRICH_METADATA=5.0
TIME_BUDGET_GENERATE_PACKAGE=3.0

# Quality Thresholds
MIN_EVERGREEN_SCORE=0.5
MIN_CONFIDENCE_SCORE=0.5
MIN_CHUNK_LENGTH=50

# Storage
RAW_ORE_DIR=raw_ore
PROCESSED_GOLD_DIR=processed_gold
LOGS_DIR=logs

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/alchemy.log
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key
